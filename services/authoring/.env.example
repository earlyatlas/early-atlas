# Early Atlas authoring service config. Copy to .env for local dev.

# Postgres DSN (required). In production this is an in-VPC connection; locally,
# point it at your own Postgres (or an SSH tunnel to one).
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/postgres

# Optional. Default 8080.
PORT=8080

# Set to 1 to apply migrations/*.sql on startup (idempotent).
RUN_MIGRATIONS=1
