# Client-side auth config for the UI (ADR 0005). PUBLIC_* is baked into the static
# build and exposed to the browser — all non-secret (public OAuth client, public
# issuer, public API URL). The SAME values are used for every environment; the
# OAuth redirect URI is derived from the page's own origin at runtime, so one build
# works on localhost, dev.earlyatlas.com, and earlyatlas.com.

PUBLIC_COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/<user-pool-id>
PUBLIC_COGNITO_CLIENT_ID=<app-client-id>
PUBLIC_COGNITO_HOSTED_UI_DOMAIN=<prefix>.auth.us-east-1.amazoncognito.com

# The one backend the UI talks to (bearer token).
PUBLIC_AUTHORING_API_URL=https://api.earlyatlas.com
