---
import Base from "../../layouts/Base.astro";
export const prerender = true;
---

<Base title="Signing in">
  <div class="prose">
    <p id="cb-msg">Signing you in…</p>
  </div>
</Base>

<script>
  import { handleCallback } from "../../lib/auth/browser";
  (async () => {
    const msg = document.getElementById("cb-msg")!;
    try {
      const ret = await handleCallback();
      location.replace(ret);
    } catch (e) {
      msg.textContent = `${(e as Error).message} — `;
      const a = document.createElement("a");
      a.href = "/";
      a.textContent = "go home and try again";
      msg.appendChild(a);
    }
  })();
</script>
