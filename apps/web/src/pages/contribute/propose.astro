---
import Base from "../../layouts/Base.astro";
export const prerender = true;
---

<Base title="Propose a change">
  <div class="contribute">
    <p class="back-link"><a href="/contribute">← Back to Contribute</a></p>
    <h1 id="form-title">Propose a change</h1>
    <p class="share-lede">
      Add a skill or activity, or suggest an edit to an existing one. Every contribution is reviewed
      before it’s published, so the library stays trustworthy while it grows.
    </p>

    <div id="auth-gate"><p class="muted">Checking your session…</p></div>

    <div id="signed-out" hidden>
      <p>Sign in to propose a change.</p>
      <p><button id="signin-btn">Sign in</button></p>
    </div>

    <div id="signed-in" hidden>
      <p class="who-line muted">
        Signed in as <strong id="who"></strong> · <a href="#" id="signout-link">Sign out</a>
      </p>

      <form id="contribute-form" novalidate>
        <div class="field">
          <div class="field-head"><label for="kind">I’m adding a</label></div>
          <select id="kind">
            <option value="skill">Skill — something a child is learning</option>
            <option value="activity">Activity — something to do together</option>
          </select>
        </div>

        <div id="fields"></div>

        <div class="field" data-key="rationale">
          <div class="field-head">
            <label for="rationale"
              >Why this change <span class="req" aria-hidden="true">*</span></label
            >
            <button type="button" class="icon-btn info" aria-label="What is this?" data-info
            ></button>
          </div>
          <textarea
            id="rationale"
            rows="2"
            maxlength="400"
            placeholder="e.g. Fills a gap between counting and simple addition."></textarea>
          <span class="char-count" data-for="rationale"></span>
          <p class="help" hidden>A sentence for the reviewer on why this belongs.</p>
        </div>

        <details class="advanced">
          <summary>Advanced: record id</summary>
          <input id="record-id" type="text" spellcheck="false" maxlength="120" />
        </details>

        <button type="submit" id="submit-btn" class="submit">Submit proposal</button>
      </form>

      <div id="result" aria-live="polite"></div>
    </div>
  </div>
</Base>

<!-- global (not scoped): the form fields are built in JS, which never receives
     Astro's scope hash — so these must be plain selectors, namespaced under .contribute. -->
<style is:global>
  .contribute {
    h1 {
      margin-bottom: var(--space-2);
    }
    .who-line {
      font-size: var(--text-sm);
      margin: 0 0 var(--space-5);
    }

    #contribute-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      max-width: 34rem;
    }
    .field {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }
    .field-head {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .field-head label {
      margin: 0;
      font-weight: 600;
    }
    .req {
      color: var(--required);
    }
    .opt {
      margin-left: 4px;
      font-weight: 400;
      font-size: var(--text-sm);
      color: var(--muted);
    }

    /* fully reset icon buttons so the global button style can't bleed in */
    .icon-btn {
      all: unset;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--muted);
    }
    .icon-btn:hover {
      color: var(--ink);
    }
    .icon-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 4px;
    }
    .icon-btn svg {
      display: block;
    }

    .help {
      margin: 2px 0 0;
      font-size: var(--text-sm);
      line-height: 1.5;
      color: var(--muted);
    }
    .char-count {
      display: none;
      font-size: 0.72rem;
      text-align: right;
      color: var(--muted);
    }
    .char-count.show {
      display: block;
    }
    .char-count.near {
      color: var(--required);
    }

    .field input[type="number"] {
      width: 9rem;
    }
    .age-row {
      display: flex;
      gap: var(--space-3);
    }
    .age-row span {
      display: block;
      font-size: var(--text-sm);
      color: var(--muted);
      margin-bottom: 2px;
    }
    .field.invalid input,
    .field.invalid textarea,
    .field.invalid select {
      border-color: var(--required);
    }

    /* chips (tags + picked references) */
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 5px 3px 10px;
      border-radius: var(--radius-pill);
      background: var(--accent-soft);
      color: var(--accent);
      border: 1px solid var(--accent-border);
      font-size: var(--text-sm);
    }
    .chip .icon-btn {
      color: inherit;
      opacity: 0.6;
    }
    .chip .icon-btn:hover {
      opacity: 1;
    }

    /* item rows (materials / steps / criteria) */
    .rows {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }
    .row {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-1) var(--space-2) var(--space-1) var(--space-3);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      background: var(--surface);
      font-size: var(--text-sm);
    }
    .row .num {
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .row .txt {
      flex: 1;
    }

    /* search-and-pick dropdown */
    .pick {
      position: relative;
    }
    .pick-suggestions {
      list-style: none;
      margin: var(--space-1) 0 0;
      padding: 0;
      position: absolute;
      left: 0;
      right: 0;
      z-index: 8;
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      background: var(--header);
      max-height: 220px;
      overflow-y: auto;
      box-shadow: 0 8px 22px rgba(0, 0, 0, 0.22);
    }
    .pick-suggestions:empty {
      display: none;
    }
    .pick-suggestions li {
      padding: var(--space-2) var(--space-3);
      cursor: pointer;
    }
    .pick-suggestions li:hover {
      background: var(--surface-2);
    }
    .pick-suggestions .pick-empty {
      color: var(--muted);
      cursor: default;
    }
    .pick-suggestions .pick-empty:hover {
      background: transparent;
    }

    .submit {
      margin-top: 0;
      align-self: flex-start;
    }
    .advanced {
      color: var(--muted);
      font-size: var(--text-sm);
    }
    .advanced summary {
      cursor: pointer;
    }
    .advanced input {
      margin-top: var(--space-2);
    }
    #result .notice {
      margin-top: var(--space-5);
      max-width: 34rem;
    }
    .issues {
      margin: var(--space-1) 0 0;
      padding-left: var(--space-5);
    }
  }
</style>

<style>
  .back-link {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
  }
  .back-link a {
    color: var(--muted);
    text-decoration: none;
  }
  .back-link a:hover {
    color: var(--accent);
  }
  #form-title {
    margin-bottom: var(--space-2);
  }
  .share-lede {
    max-width: var(--prose);
    margin: var(--space-2) 0 var(--space-6);
    line-height: 1.6;
  }
</style>

<script>
  import { getUser, login, logout, api, isAuthConfigured } from "../../lib/auth/browser";

  const ICON_INFO =
    '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11v5"/><path d="M12 8h.01"/></svg>';
  const ICON_X =
    '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';

  type FType = "text" | "prose" | "number" | "tags" | "items" | "pick" | "agerange";
  interface FieldDef {
    key: string;
    label: string;
    type: FType;
    help: string;
    placeholder?: string;
    refKind?: string;
    max?: number; // maxlength (prose/text) or per-item maxlength (tags/items)
    optional?: boolean;
    ordered?: boolean; // numbered rows (steps)
  }

  const KINDS: Record<string, { noun: string; fields: FieldDef[]; makeId: (rec: any) => string }> =
    {
      skill: {
        noun: "skill",
        fields: [
          {
            key: "title",
            label: "Title",
            type: "text",
            max: 80,
            placeholder: "e.g. Counts to ten",
            help: "The name people search for and see across the library. Keep it short and plain.",
          },
          {
            key: "short_description",
            label: "Short description",
            type: "prose",
            max: 300,
            placeholder: "e.g. Says number words in order from one to ten.",
            help: "Sets what the skill covers, in a child’s terms. This is the summary shown on the skill’s page.",
          },
          {
            key: "developmental_purpose",
            label: "Why it matters",
            type: "prose",
            max: 500,
            placeholder: "e.g. Lays the groundwork for one-to-one counting and early arithmetic.",
            help: "How this skill fits a child’s growth and what it builds toward. Reviewers lean on this to place the skill.",
          },
          {
            key: "domain_ids",
            label: "Domain",
            type: "pick",
            refKind: "domain",
            help: "Files the skill under one developmental domain so it appears in the right part of the library.",
          },
          {
            key: "standard_ids",
            label: "Milestone goal",
            type: "pick",
            refKind: "standard",
            optional: true,
            help: "Links the ELOF developmental milestone this skill works toward — that connection is what powers the Milestones page.",
          },
          {
            key: "__age",
            label: "Typical age (months)",
            type: "agerange",
            help: "When this skill usually emerges, in months. Helps families find what fits their child.",
          },
          {
            key: "prerequisite_skill_ids",
            label: "Prerequisite skills",
            type: "pick",
            refKind: "skill",
            optional: true,
            help: "Skills usually learned first — these connect into a path. Leave empty for a foundational skill.",
          },
          {
            key: "mastery_criteria",
            label: "How you know it’s mastered",
            type: "items",
            max: 140,
            placeholder: "e.g. Counts ten objects without skipping a number",
            help: "Concrete signs the skill is mastered. Add several — one per line.",
          },
          {
            key: "tags",
            label: "Tags",
            type: "tags",
            max: 30,
            placeholder: "Type a keyword and press Enter",
            help: "Keywords that help this turn up in search. Add a few — one at a time.",
          },
        ],
        makeId: (rec) => `ea.skill.${domainSeg(rec.domain_ids)}.${rec.slug || "new"}`,
      },
      activity: {
        noun: "activity",
        fields: [
          {
            key: "title",
            label: "Title",
            type: "text",
            max: 80,
            placeholder: "e.g. Sort buttons by color",
            help: "The name people search for and see across the library. Keep it short and plain.",
          },
          {
            key: "summary",
            label: "Summary",
            type: "prose",
            max: 300,
            placeholder: "e.g. Children sort a pile of buttons into cups by color.",
            help: "What you and the child do together, in a sentence or two. This is the summary shown on the activity’s page.",
          },
          {
            key: "supported_skill_ids",
            label: "Skill it supports",
            type: "pick",
            refKind: "skill",
            help: "Links the skill this activity gives practice with, so the two connect in the library.",
          },
          {
            key: "__age",
            label: "Typical age (months)",
            type: "agerange",
            help: "When this activity fits best, in months. Helps families find what suits their child.",
          },
          {
            key: "materials",
            label: "Materials",
            type: "items",
            max: 80,
            placeholder: "e.g. A handful of buttons",
            help: "What you need on hand. Add each item — one at a time.",
          },
          {
            key: "steps",
            label: "Steps",
            type: "items",
            max: 200,
            ordered: true,
            placeholder: "e.g. Tip the buttons onto a tray",
            help: "What you do, in order. Add each step — one at a time.",
          },
          {
            key: "duration_minutes",
            label: "Duration (minutes)",
            type: "number",
            placeholder: "15",
            help: "Roughly how long it runs, so families can plan.",
          },
          {
            key: "tags",
            label: "Tags",
            type: "tags",
            max: 30,
            placeholder: "Type a keyword and press Enter",
            help: "Keywords that help this turn up in search. Add a few — one at a time.",
          },
        ],
        makeId: (rec) => `ea.activity.${rec.slug || "new"}`,
      },
    };

  const AGE_MIN = 0,
    AGE_MAX = 84,
    DURATION_MAX = 180;
  const slugify = (s: string) =>
    s
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");
  const domainSeg = (ids?: string[]) =>
    ids && ids[0] ? ids[0].replace(/^ea\.domain\./, "").replace(/\./g, "-") : "general";
  const esc = (s: string) =>
    s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!);

  let recordIndex: { id: string; title: string; kind: string; code?: string }[] | null = null;
  async function records() {
    if (!recordIndex) recordIndex = await (await fetch("/records.json")).json();
    return recordIndex!;
  }

  const picks: Record<string, { id: string; title: string }[]> = {}; // pick fields
  const lists: Record<string, string[]> = {}; // tags + items
  let idEdited = false;
  // Edit mode: /contribute?edit=<id> proposes changes to an existing record.
  const EDIT_ID = new URLSearchParams(location.search).get("edit");
  const RETURN_TO = location.pathname + location.search; // bring sign-in back to the edit
  let editId: string | null = null;
  let fieldsEl!: HTMLElement,
    kindEl!: HTMLSelectElement,
    idEl!: HTMLInputElement,
    resultEl!: HTMLElement;

  function el(tag: string, attrs: Record<string, string> = {}, html?: string) {
    const n = document.createElement(tag);
    for (const [k, v] of Object.entries(attrs)) n.setAttribute(k, v);
    if (html !== undefined) n.innerHTML = html;
    return n;
  }
  function iconBtn(icon: string, label: string, cls = "") {
    return el(
      "button",
      { type: "button", class: `icon-btn ${cls}`.trim(), "aria-label": label },
      icon,
    );
  }

  function fieldHead(def: FieldDef) {
    const h = el("div", { class: "field-head" });
    const reqMark = def.optional
      ? ' <span class="opt">optional</span>'
      : ' <span class="req" aria-hidden="true">*</span>';
    h.appendChild(el("label", {}, `${esc(def.label)}${reqMark}`));
    const info = iconBtn(ICON_INFO, `What is “${def.label}”?`, "info");
    info.setAttribute("data-info", ""); // the click handler matches [data-info]
    h.appendChild(info);
    return h;
  }

  function wireCounter(input: HTMLInputElement | HTMLTextAreaElement, max: number) {
    const c = el("span", { class: "char-count" });
    const upd = () => {
      const n = input.value.length;
      c.textContent = `${n} / ${max}`;
      c.classList.toggle("show", n > max * 0.75);
      c.classList.toggle("near", n > max * 0.92);
    };
    input.addEventListener("input", upd);
    upd();
    return c;
  }

  // chips for tags
  function tagInput(def: FieldDef) {
    lists[def.key] = lists[def.key] || [];
    const chips = el("div", { class: "chips" });
    const input = el("input", {
      type: "text",
      placeholder: def.placeholder ?? "",
      maxlength: String(def.max ?? 40),
      autocomplete: "off",
    }) as HTMLInputElement;
    const render = () => {
      chips.innerHTML = "";
      lists[def.key].forEach((tag, i) => {
        const chip = el("span", { class: "chip" }, esc(tag));
        const x = iconBtn(ICON_X, `Remove ${esc(tag)}`);
        x.addEventListener("click", () => {
          lists[def.key].splice(i, 1);
          render();
        });
        chip.appendChild(x);
        chips.appendChild(chip);
      });
    };
    const add = () => {
      const v = input.value.trim().replace(/,$/, "").trim();
      if (v && !lists[def.key].includes(v)) lists[def.key].push(v);
      input.value = "";
      render();
    };
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === ",") {
        e.preventDefault();
        add();
      }
    });
    input.addEventListener("blur", add);
    const wrap = el("div");
    wrap.append(chips, input);
    render(); // show any seeded values (edit mode)
    return wrap;
  }

  // stacked removable rows for materials / steps / criteria
  function itemList(def: FieldDef) {
    lists[def.key] = lists[def.key] || [];
    const rows = el("ol", { class: "rows" });
    const input = el("input", {
      type: "text",
      placeholder: def.placeholder ?? "",
      maxlength: String(def.max ?? 200),
      autocomplete: "off",
    }) as HTMLInputElement;
    const render = () => {
      rows.innerHTML = "";
      lists[def.key].forEach((item, i) => {
        const row = el("li", { class: "row" });
        if (def.ordered) row.appendChild(el("span", { class: "num" }, `${i + 1}.`));
        row.appendChild(el("span", { class: "txt" }, esc(item)));
        const x = iconBtn(ICON_X, `Remove`);
        x.addEventListener("click", () => {
          lists[def.key].splice(i, 1);
          render();
        });
        row.appendChild(x);
        rows.appendChild(row);
      });
    };
    const add = () => {
      const v = input.value.trim();
      if (v) lists[def.key].push(v);
      input.value = "";
      render();
    };
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        add();
      }
    });
    input.addEventListener("blur", add);
    const wrap = el("div");
    wrap.append(rows, input);
    render(); // show any seeded values (edit mode)
    return wrap;
  }

  const refLabel = (r: { title: string; code?: string }) =>
    r.code ? `${r.code} · ${r.title}` : r.title;

  function pickInput(def: FieldDef) {
    picks[def.key] = picks[def.key] || [];
    const single = def.key === "domain_ids"; // a skill lives in exactly one domain
    const chips = el("div", { class: "chips" });
    const wrap = el("div", { class: "pick" });
    const input = el("input", {
      type: "text",
      placeholder: "Type to filter, or click to browse…",
      autocomplete: "off",
      role: "combobox",
      "aria-expanded": "false",
    }) as HTMLInputElement;
    const sugg = el("ul", { class: "pick-suggestions" });

    const render = () => {
      chips.innerHTML = "";
      picks[def.key].forEach((item, i) => {
        const chip = el("span", { class: "chip" }, esc(item.title));
        const x = iconBtn(ICON_X, `Remove ${esc(item.title)}`);
        x.addEventListener("click", () => {
          picks[def.key].splice(i, 1);
          render();
          refreshId();
          show(); // refresh the open list (removed item becomes selectable again)
        });
        chip.appendChild(x);
        chips.appendChild(chip);
      });
      // a single-select field hides its input once something is chosen
      input.hidden = single && picks[def.key].length > 0;
    };

    const close = () => {
      sugg.innerHTML = "";
      input.setAttribute("aria-expanded", "false");
    };
    const show = async () => {
      const q = input.value.trim().toLowerCase();
      const all = await records();
      const matches = all
        .filter((r) => r.kind === def.refKind && !picks[def.key].some((p) => p.id === r.id))
        .filter((r) => !q || refLabel(r).toLowerCase().includes(q))
        .slice(0, 50);
      sugg.innerHTML = "";
      input.setAttribute("aria-expanded", matches.length ? "true" : "false");
      if (!matches.length) {
        sugg.appendChild(el("li", { class: "pick-empty", "aria-disabled": "true" }, "No matches"));
        return;
      }
      for (const r of matches) {
        const li = el("li", {}, esc(refLabel(r)));
        li.addEventListener("mousedown", (e) => {
          e.preventDefault(); // pick before the input's blur fires
          if (single) picks[def.key] = [];
          picks[def.key].push({ id: r.id, title: refLabel(r) });
          input.value = "";
          render();
          refreshId();
          single ? close() : show();
        });
        sugg.appendChild(li);
      }
    };

    let t: number | undefined;
    input.addEventListener("input", () => {
      window.clearTimeout(t);
      t = window.setTimeout(show, 120);
    });
    input.addEventListener("focus", show);
    input.addEventListener("blur", () => setTimeout(close, 120));

    wrap.append(input, sugg);
    const outer = el("div");
    outer.append(chips, wrap);
    render(); // show any seeded chips (edit mode)
    return outer;
  }

  async function renderFields(kind: string, seed?: Record<string, any>) {
    fieldsEl.innerHTML = "";
    fieldsEl.style.display = "flex";
    fieldsEl.style.flexDirection = "column";
    fieldsEl.style.gap = "var(--space-5)";
    for (const key of Object.keys(picks)) delete picks[key];
    for (const key of Object.keys(lists)) delete lists[key];

    // Seed pick/tag/item state before building, so each builder renders prefilled.
    if (seed) {
      const idx = await records();
      for (const def of KINDS[kind].fields) {
        const v = seed[def.key];
        if (def.type === "pick") {
          picks[def.key] = (Array.isArray(v) ? v : []).map((id: string) => {
            const r = idx.find((x) => x.id === id);
            return { id, title: r ? refLabel(r) : id };
          });
        } else if (def.type === "tags" || def.type === "items") {
          lists[def.key] = Array.isArray(v) ? [...v] : [];
        }
      }
    }

    for (const def of KINDS[kind].fields) {
      const sv = seed ? seed[def.key] : undefined;
      const row = el("div", { class: "field", "data-key": def.key });
      row.appendChild(fieldHead(def));
      if (def.type === "text") {
        const i = el("input", {
          type: "text",
          id: `f-${def.key}`,
          maxlength: String(def.max ?? 200),
          placeholder: def.placeholder ?? "",
        }) as HTMLInputElement;
        if (sv != null) i.value = String(sv);
        if (def.key === "title") i.addEventListener("input", refreshId);
        row.append(i, wireCounter(i, def.max ?? 200));
      } else if (def.type === "prose") {
        const ta = el("textarea", {
          id: `f-${def.key}`,
          rows: "3",
          maxlength: String(def.max ?? 500),
          placeholder: def.placeholder ?? "",
        }) as HTMLTextAreaElement;
        if (sv != null) ta.value = String(sv);
        row.append(ta, wireCounter(ta, def.max ?? 500));
      } else if (def.type === "number") {
        const i = el("input", {
          type: "number",
          id: `f-${def.key}`,
          min: "1",
          max: String(DURATION_MAX),
          placeholder: def.placeholder ?? "",
        }) as HTMLInputElement;
        if (sv != null) i.value = String(sv);
        row.appendChild(i);
      } else if (def.type === "agerange") {
        const a = seed?.age_range_months ?? {};
        const ar = el("div", { class: "age-row" });
        ar.innerHTML =
          `<div><span>From</span><input type="number" id="f-age-min" min="${AGE_MIN}" max="${AGE_MAX}" placeholder="36" value="${a.min ?? ""}"></div>` +
          `<div><span>To</span><input type="number" id="f-age-max" min="${AGE_MIN}" max="${AGE_MAX}" placeholder="48" value="${a.max ?? ""}"></div>`;
        row.appendChild(ar);
      } else if (def.type === "tags") {
        row.appendChild(tagInput(def));
      } else if (def.type === "items") {
        row.appendChild(itemList(def));
      } else if (def.type === "pick") {
        row.appendChild(pickInput(def));
      }
      row.appendChild(el("p", { class: "help", hidden: "hidden" }, esc(def.help)));
      fieldsEl.appendChild(row);
    }

    if (editId) {
      // editing keeps the existing id; never regenerate it from the title
      idEl.value = editId;
      idEdited = true;
    } else {
      idEdited = false;
      refreshId();
    }
  }

  const val = (key: string) => {
    const e = document.getElementById(`f-${key}`) as HTMLInputElement | HTMLTextAreaElement | null;
    return e ? e.value.trim() : "";
  };
  function refreshId() {
    if (idEdited) return;
    idEl.value = KINDS[kindEl.value].makeId({
      slug: slugify(val("title")),
      domain_ids: picks.domain_ids?.map((p) => p.id),
    });
  }
  function markInvalid(key: string, bad: boolean) {
    document.querySelector(`.field[data-key="${key}"]`)?.classList.toggle("invalid", bad);
  }

  function validate(kind: string): string[] {
    const missing: string[] = [];
    for (const def of KINDS[kind].fields) {
      if (def.optional) continue;
      let ok = true;
      if (def.type === "pick") ok = (picks[def.key] || []).length > 0;
      else if (def.type === "tags" || def.type === "items") ok = (lists[def.key] || []).length > 0;
      else if (def.type === "agerange") {
        const lo = parseInt(val("age-min"), 10),
          hi = parseInt(val("age-max"), 10);
        ok = !Number.isNaN(lo) && !Number.isNaN(hi) && lo >= AGE_MIN && hi <= AGE_MAX && hi >= lo;
      } else if (def.type === "number") {
        const n = parseInt(val(def.key), 10);
        ok = !Number.isNaN(n) && n >= 1 && n <= DURATION_MAX;
      } else ok = val(def.key).length > 0;
      markInvalid(def.key, !ok);
      if (!ok) missing.push(def.label);
    }
    return missing;
  }

  // update=true → only the editable field values (the update_fields op merges these
  // over the existing record; id/slug/status/locale must stay as they are).
  function buildRecord(kind: string, update = false) {
    const rec: any = update
      ? {}
      : { id: idEl.value.trim(), slug: slugify(val("title")), status: "draft", locale: "en-US" };
    for (const def of KINDS[kind].fields) {
      if (def.type === "agerange")
        rec.age_range_months = {
          min: parseInt(val("age-min"), 10),
          max: parseInt(val("age-max"), 10),
        };
      else if (def.type === "pick") {
        const ids = (picks[def.key] || []).map((p) => p.id);
        if (ids.length) rec[def.key] = ids;
      } else if (def.type === "tags" || def.type === "items") {
        const v = lists[def.key] || [];
        if (v.length) rec[def.key] = v;
      } else if (def.type === "number") rec[def.key] = parseInt(val(def.key), 10);
      else {
        const v = val(def.key);
        if (v) rec[def.key] = v;
      }
    }
    return rec;
  }

  function showResult(html: string, bad = false) {
    resultEl.innerHTML = `<div class="notice ${bad ? "bad" : ""}" role="note">${html}</div>`;
  }

  function initForm() {
    fieldsEl = document.getElementById("fields")!;
    kindEl = document.getElementById("kind") as HTMLSelectElement;
    idEl = document.getElementById("record-id") as HTMLInputElement;
    resultEl = document.getElementById("result")!;
    idEl.addEventListener("input", () => (idEdited = true));
    kindEl.addEventListener("change", () => renderFields(kindEl.value));

    const rat = document.getElementById("rationale") as HTMLTextAreaElement;
    const ratCount = document.querySelector('.char-count[data-for="rationale"]') as HTMLElement;
    const updRat = () => {
      const n = rat.value.length;
      ratCount.textContent = `${n} / 400`;
      ratCount.classList.toggle("show", n > 300);
      ratCount.classList.toggle("near", n > 368);
    };
    rat.addEventListener("input", updRat);
    updRat();
    document.querySelector('.field[data-key="rationale"] .info')!.innerHTML = ICON_INFO;

    // info: click the icon to toggle the help line below the field (stays open while typing)
    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("[data-info]");
      if (!btn) return;
      e.preventDefault();
      const help = btn.closest(".field")?.querySelector(".help") as HTMLElement | null;
      const open = help && !help.hasAttribute("hidden");
      document.querySelectorAll(".help").forEach((p) => p.setAttribute("hidden", ""));
      if (help && !open) help.removeAttribute("hidden");
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape")
        document.querySelectorAll(".help").forEach((p) => p.setAttribute("hidden", ""));
    });

    document.getElementById("contribute-form")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const kind = kindEl.value;
      const missing = validate(kind);
      const rationale = rat.value.trim();
      document
        .querySelector('.field[data-key="rationale"]')!
        .classList.toggle("invalid", rationale.length === 0);
      if (rationale.length === 0) missing.push("Why this change");
      if (missing.length) {
        showResult(
          `<strong>Please complete the required fields.</strong><ul class="issues">${missing.map((m) => `<li>${esc(m)}</li>`).join("")}</ul>`,
          true,
        );
        return;
      }
      const btn = document.getElementById("submit-btn") as HTMLButtonElement;
      const noun = KINDS[kind].noun;
      const changeset = {
        id: "cs_" + Math.random().toString(36).slice(2, 10),
        title: editId ? `Edit ${noun}: ${val("title")}` : `New ${noun}: ${val("title")}`,
        rationale,
        operations: editId
          ? [{ op: "update_fields", id: editId, fields: buildRecord(kind, true) }]
          : [{ op: "create_record", record: buildRecord(kind) }],
      };
      btn.disabled = true;
      showResult("Submitting…");
      try {
        const res = await api("/api/proposals", {
          method: "POST",
          body: JSON.stringify({ changeset, title: changeset.title, rationale: changeset.rationale }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.status === 201) {
          showResult(
            `<strong>Thank you — your ${editId ? "edit" : "proposal"} is in.</strong> It’s queued as a draft for review (id <code>${esc(data.id ?? "")}</code>).`,
          );
          if (!editId) {
            // keep an edit on screen so the contributor can see what they sent
            (document.getElementById("contribute-form") as HTMLFormElement).reset();
            renderFields(kind);
            updRat();
          }
        } else if (res.status === 401) {
          showResult(`Your session expired. <a href="#" id="relogin">Sign in again</a>.`, true);
          document.getElementById("relogin")?.addEventListener("click", (ev) => {
            ev.preventDefault();
            login(RETURN_TO);
          });
        } else {
          const issues =
            data.validation?.errors?.map((x: string) => `<li>${esc(x)}</li>`).join("") || "";
          showResult(
            `<strong>${esc(data.error || "Could not submit.")}</strong>${issues ? `<ul class="issues">${issues}</ul>` : ""}`,
            true,
          );
        }
      } catch (err) {
        showResult(`Network error: ${esc(String(err))}`, true);
      } finally {
        btn.disabled = false;
      }
    });

    if (EDIT_ID) enterEdit(EDIT_ID);
    else renderFields(kindEl.value);
  }

  // Edit mode: load the record's current values and prefill the form as an update.
  async function enterEdit(id: string) {
    try {
      const res = await fetch(`/records/${encodeURIComponent(id)}.json`);
      if (!res.ok) throw new Error(String(res.status));
      const rec = await res.json();
      editId = rec.id;
      kindEl.value = rec.kind;
      kindEl.disabled = true; // the kind of an existing record can't change
      idEl.readOnly = true;
      const fTitle = document.getElementById("form-title");
      if (fTitle) fTitle.textContent = "Propose an edit";
      const kLabel = document.querySelector('label[for="kind"]');
      if (kLabel) kLabel.textContent = "Editing a";
      document.getElementById("submit-btn")!.textContent = "Submit edit";
      await renderFields(rec.kind, rec.data);
      document.getElementById("share")?.scrollIntoView({ behavior: "smooth", block: "start" });
    } catch {
      editId = null;
      kindEl.disabled = false;
      showResult(
        `Couldn’t load that record to edit. <a href="/contribute">Start a new proposal</a> instead.`,
        true,
      );
      renderFields(kindEl.value);
    }
  }

  (function main() {
    const gate = document.getElementById("auth-gate")!;
    if (!isAuthConfigured()) {
      gate.innerHTML =
        '<div class="notice bad" role="note">Sign-in isn’t configured for this build.</div>';
      return;
    }
    const user = getUser();
    gate.hidden = true;
    if (!user) {
      document.getElementById("signed-out")!.hidden = false;
      if (EDIT_ID)
        document.querySelector("#signed-out p")!.textContent = "Sign in to suggest an edit.";
      document.getElementById("signin-btn")!.addEventListener("click", () => login(RETURN_TO));
      return;
    }
    document.getElementById("signed-in")!.hidden = false;
    document.getElementById("who")!.textContent = user.email ?? user.sub;
    document.getElementById("signout-link")!.addEventListener("click", (e) => {
      e.preventDefault();
      logout();
    });
    initForm();
  })();
</script>
